#!/usr/bin/env bash
# SessionStart hook — injects the "always check for an applicable skill" reminder
# at the start of every session, so project skills activate proactively.
#
# Adapted from obra/superpowers (MIT, © Jesse Vincent). Self-locating: it reads
# the reminder from skills/using-superpowers/SKILL.md relative to its own path,
# so the whole .claude/ folder can be copied into any project unchanged.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLAUDE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${CLAUDE_DIR}/skills/using-superpowers/SKILL.md"

content="$(cat "${SKILL_FILE}" 2>/dev/null || echo "")"
if [ -z "${content}" ]; then
  # Nothing to inject — emit an empty object so the hook is a no-op.
  printf '{}\n'
  exit 0
fi

# Escape a string for embedding inside a JSON string value.
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped="$(escape_for_json "$content")"
ctx="<EXTREMELY_IMPORTANT>\nThis project has skills in .claude/skills/. Before ANY response or action, if there is even a 1% chance a skill applies, invoke it with the Skill tool first. The full guide follows:\n\n${escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$ctx"
exit 0
