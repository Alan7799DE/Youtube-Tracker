# Copiá este archivo a backend/.env y completá los valores.
# .env está en .gitignore: NUNCA se commitea. Acá solo van placeholders.
# Guía paso a paso para conseguir las claves: docs/guia-fase-1-testeo.md

# OpenAI — verificación LLM de R3/R4. Requiere billing activado (pago por uso).
# platform.openai.com -> API keys
OPENAI_API_KEY=sk-...

# YouTube Data API v3 — metadata del video (título, descripción, canal).
# console.cloud.google.com -> proyecto -> habilitar "YouTube Data API v3" -> Credenciales -> API key
YOUTUBE_API_KEY=AIza...

# Modelo de OpenAI a usar. Default razonable y barato: gpt-4o-mini.
LLM_MODEL=gpt-4o-mini
